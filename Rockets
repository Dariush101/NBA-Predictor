# Get team roster

# Gets all players on the team

# It gets a team’s roster for a season 
# and returns only the players who are not in the injured players list.
def get_active_players(HOUSTON: str, season: str, injured_players: list):
    team_id = get_team_id(HOUSTON)

    roster_df = commonteamroster.CommonTeamRoster(
        team_id=team_id,
        season=season
    ).get_data_frames()[0]

    if roster_df.empty or "PLAYER" not in roster_df.columns:
        raise ValueError(f"Could not fetch roster for {HOUSTON} in {season}.")

    roster = roster_df["PLAYER"].dropna().astype(str).tolist()

    return [p for p in roster if p not in injured_players]



# Pulls stats for one player in one season

# It fetches a player’s game logs for a season, cleans
# and formats the data, and returns a structured DataFrame with their stats.
def fetch_player_logs_for_season(player_name: str, season: str) -> pd.DataFrame:
    try:
        player_id = get_player_id(player_name)
    except ValueError as e:
        print(f"Skipping {player_name} for {season}: {e}")
        return pd.DataFrame()

    first_name, last_name = split_name(player_name)

    time.sleep(0.6)

    try:
        gamelog = playergamelog.PlayerGameLog(
            player_id=player_id,
            season=season,
            season_type_all_star="Regular Season"
        )
        df = gamelog.get_data_frames()[0]
    except Exception as e:
        print(f"Skipping {player_name} for {season}: could not fetch logs ({e})")
        return pd.DataFrame()

    if df.empty:
        print(f"No regular season data for {player_name} in {season}.")
        return pd.DataFrame()

    df = df.rename(columns={
        "Game_ID": "game_id",
        "GAME_DATE": "game_date",
        "MATCHUP": "matchup",
        "WL": "wl",
        "MIN": "numMinutes",
        "PTS": "points",
        "AST": "ast",
        "REB": "reb",
        "STL": "stl",
        "BLK": "blk",
        "TOV": "tov",
        "FG_PCT": "fg_pct",
        "FG3_PCT": "fg3_pct",
        "FT_PCT": "ft_pct",
        "PLUS_MINUS": "plus_minus"
    })

    numeric_cols = [
        "numMinutes", "points", "ast", "reb", "stl",
        "blk", "tov", "fg_pct", "fg3_pct", "ft_pct", "plus_minus"
    ]
    for col in numeric_cols:
        df[col] = pd.to_numeric(df[col], errors="coerce")

    df["player_id"] = player_id
    df["firstName"] = first_name
    df["lastName"] = last_name
    df["full_name"] = player_name
    df["season"] = season
    df["updated_at"] = datetime.now().isoformat(timespec="seconds")

    keep_cols = [
        "game_id", "player_id", "firstName", "lastName", "full_name", "season",
        "game_date", "matchup", "wl", "numMinutes", "points", "ast",
        "reb", "stl", "blk", "tov", "fg_pct", "fg3_pct", "ft_pct",
        "plus_minus", "updated_at"
    ]

    return df[keep_cols].copy()










def generate_seasons(current_season: str, num_years: int = 7):
    start_year = int(current_season.split("-")[0])
    seasons = []

    for year in range(start_year - num_years + 1, start_year + 1):
        end_year_short = str(year + 1)[-2:]
        seasons.append(f"{year}-{end_year_short}")

    return seasons


def get_team_id(HOUSTON: str) -> int:
    nba_teams = teams.get_teams()
    for team in nba_teams:
        if team["full_name"].lower() == HOUSTON.lower():
            return int(team["id"])
    raise ValueError(f"Team '{HOUSTON}' not found.")






def recreate_table():
    conn = sqlite3.connect(DB_PATH)
    cur = conn.cursor()

    cur.execute(f"DROP TABLE IF EXISTS {TABLE}")

    cur.execute(f"""
        CREATE TABLE {TABLE} (
            game_id TEXT,
            player_id INTEGER,
            firstName TEXT,
            lastName TEXT,
            full_name TEXT,
            season TEXT,
            game_date TEXT,
            matchup TEXT,
            wl TEXT,
            numMinutes REAL,
            points REAL,
            ast REAL,
            reb REAL,
            stl REAL,
            blk REAL,
            tov REAL,
            fg_pct REAL,
            fg3_pct REAL,
            ft_pct REAL,
            plus_minus REAL,

            tm_points_total REAL,
            tm_ast_total REAL,
            tm_reb_total REAL,
            tm_minutes_total REAL,
            tm_fg_pct REAL,

            top_tm_points REAL,
            second_tm_points REAL,
            third_tm_points REAL,
            top3_tm_points_total REAL,
            player_team_points_share REAL,

            updated_at TEXT,

            PRIMARY KEY (game_id, player_id)
        )
    """)

    conn.commit()
    conn.close()


def split_name(full_name: str):
    parts = full_name.strip().split()
    first = parts[0] if parts else ""
    last = " ".join(parts[1:]) if len(parts) > 1 else ""
    return first, last


def get_player_id(full_name: str) -> int:
    search_names = [full_name] + PLAYER_NAME_FALLBACKS.get(full_name, [])

    for name in search_names:
        matches = players.find_players_by_full_name(name)
        if matches:
            return int(matches[0]["id"])

    raise ValueError(f"Player '{full_name}' not found in nba_api.")




def fetch_all_players_logs(active_players, seasons) -> pd.DataFrame:
    all_dfs = []

    for player_name in active_players:
        print(f"\n{'=' * 100}")
        print(f"FETCHING LOGS FOR {player_name.upper()}")
        print(f"{'=' * 100}")

        for season in seasons:
            print(f"Fetching {player_name} logs for {season}...")
            season_df = fetch_player_logs_for_season(player_name, season)

            if not season_df.empty:
                all_dfs.append(season_df)

    if not all_dfs:
        return pd.DataFrame()

    combined = pd.concat(all_dfs, ignore_index=True)
    combined["game_date"] = pd.to_datetime(combined["game_date"], errors="coerce")
    combined = combined.dropna(subset=["game_id", "player_id", "game_date"])
    combined = combined.sort_values(["game_date", "full_name"]).reset_index(drop=True)

    return combined


def insert_logs(df: pd.DataFrame):
    if df.empty:
        print("No data fetched.")
        return

    df = df.copy()
    df["game_date"] = pd.to_datetime(df["game_date"], errors="coerce").dt.strftime("%Y-%m-%d")
    df["updated_at"] = df["updated_at"].astype(str)

    rows = [
        tuple(None if pd.isna(x) else x for x in row)
        for row in df.itertuples(index=False, name=None)
    ]

    conn = sqlite3.connect(DB_PATH)
    cur = conn.cursor()

    sql = f"""
        INSERT OR REPLACE INTO {TABLE} (
            game_id, player_id, firstName, lastName, full_name, season,
            game_date, matchup, wl, numMinutes, points, ast,
            reb, stl, blk, tov, fg_pct, fg3_pct, ft_pct,
            plus_minus, updated_at
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    """

    cur.executemany(sql, rows)
    conn.commit()
    conn.close()

    print(f"Inserted {len(df)} player game logs into {TABLE}.")


def update_teammate_context_from_db(active_players):
    conn = sqlite3.connect(DB_PATH)

    df = pd.read_sql_query(f"""
        SELECT
            game_id,
            player_id,
            full_name,
            points,
            ast,
            reb,
            numMinutes,
            fg_pct
        FROM {TABLE}
        ORDER BY game_id, full_name
    """, conn)

    if df.empty:
        conn.close()
        print("No rows found for teammate context update.")
        return

    numeric_cols = ["points", "ast", "reb", "numMinutes", "fg_pct"]
    for col in numeric_cols:
        df[col] = pd.to_numeric(df[col], errors="coerce")

    updates = []

    for game_id, game_df in df.groupby("game_id"):
        relevant_df = game_df[game_df["full_name"].isin(active_players)].copy()

        if relevant_df.empty:
            continue

        for _, row in relevant_df.iterrows():
            current_player_id = row["player_id"]
            teammates = relevant_df[relevant_df["player_id"] != current_player_id].copy()

            player_points = float(row["points"]) if pd.notna(row["points"]) else 0.0
            team_points_total_all = float(relevant_df["points"].fillna(0).sum())
            player_team_points_share = (
                player_points / team_points_total_all if team_points_total_all > 0 else None
            )

            if teammates.empty:
                tm_points_total = 0.0
                tm_ast_total = 0.0
                tm_reb_total = 0.0
                tm_minutes_total = 0.0
                tm_fg_pct = 0.0
                top_tm_points = 0.0
                second_tm_points = 0.0
                third_tm_points = 0.0
                top3_tm_points_total = 0.0
            else:
                teammate_points_sorted = teammates["points"].fillna(0).sort_values(ascending=False).tolist()

                top_tm_points = float(teammate_points_sorted[0]) if len(teammate_points_sorted) > 0 else 0.0
                second_tm_points = float(teammate_points_sorted[1]) if len(teammate_points_sorted) > 1 else 0.0
                third_tm_points = float(teammate_points_sorted[2]) if len(teammate_points_sorted) > 2 else 0.0
                top3_tm_points_total = top_tm_points + second_tm_points + third_tm_points

                tm_points_total = float(teammates["points"].sum(skipna=True))
                tm_ast_total = float(teammates["ast"].sum(skipna=True))
                tm_reb_total = float(teammates["reb"].sum(skipna=True))
                tm_minutes_total = float(teammates["numMinutes"].sum(skipna=True))
                tm_fg_pct = (
                    float(teammates["fg_pct"].mean(skipna=True))
                    if teammates["fg_pct"].notna().any() else None
                )

            updates.append((
                tm_points_total,
                tm_ast_total,
                tm_reb_total,
                tm_minutes_total,
                tm_fg_pct,
                top_tm_points,
                second_tm_points,
                third_tm_points,
                top3_tm_points_total,
                player_team_points_share,
                game_id,
                current_player_id
            ))

    cur = conn.cursor()
    cur.executemany(f"""
        UPDATE {TABLE}
        SET
            tm_points_total = ?,
            tm_ast_total = ?,
            tm_reb_total = ?,
            tm_minutes_total = ?,
            tm_fg_pct = ?,
            top_tm_points = ?,
            second_tm_points = ?,
            third_tm_points = ?,
            top3_tm_points_total = ?,
            player_team_points_share = ?
        WHERE game_id = ? AND player_id = ?
    """, updates)

    conn.commit()
    conn.close()

    print(f"Updated teammate context from database for {len(updates)} rows.")


def load_data_from_db(active_players) -> pd.DataFrame:
    conn = sqlite3.connect(DB_PATH)
    placeholders = ",".join(["?"] * len(active_players))

    query = f"""
        SELECT
            game_id,
            player_id,
            firstName,
            lastName,
            full_name,
            season,
            game_date,
            matchup,
            wl,
            numMinutes,
            points,
            ast,
            reb,
            stl,
            blk,
            tov,
            fg_pct,
            fg3_pct,
            ft_pct,
            plus_minus,
            tm_points_total,
            tm_ast_total,
            tm_reb_total,
            tm_minutes_total,
            tm_fg_pct,
            top_tm_points,
            second_tm_points,
            third_tm_points,
            top3_tm_points_total,
            player_team_points_share,
            updated_at
        FROM {TABLE}
        WHERE full_name IN ({placeholders})
        ORDER BY full_name, game_date
    """

    df = pd.read_sql_query(query, conn, params=active_players)
    conn.close()

    if df.empty:
        return df

    df["game_date"] = pd.to_datetime(df["game_date"], errors="coerce")

    numeric_cols = [
        "numMinutes", "points", "ast", "reb", "stl", "blk", "tov",
        "fg_pct", "fg3_pct", "ft_pct", "plus_minus",
        "tm_points_total", "tm_ast_total", "tm_reb_total", "tm_minutes_total",
        "tm_fg_pct", "top_tm_points", "second_tm_points", "third_tm_points",
        "top3_tm_points_total", "player_team_points_share"
    ]
    for col in numeric_cols:
        df[col] = pd.to_numeric(df[col], errors="coerce")

    return df


def add_rolling_features(df: pd.DataFrame) -> pd.DataFrame:
    if df.empty:
        return df

    df = df.sort_values(["full_name", "game_date"]).copy()
    group = df.groupby("full_name", group_keys=False)

    rolling_sources = [
        "points", "ast", "reb", "numMinutes", "fg_pct", "fg3_pct", "ft_pct",
        "tov", "plus_minus", "tm_points_total", "tm_ast_total", "tm_reb_total",
        "tm_minutes_total", "tm_fg_pct", "top_tm_points", "second_tm_points",
        "third_tm_points", "top3_tm_points_total", "player_team_points_share"
    ]

    for col in rolling_sources:
        df[f"{col}_last3"] = group[col].transform(lambda s: s.shift(1).rolling(3, min_periods=1).mean())
        df[f"{col}_last5"] = group[col].transform(lambda s: s.shift(1).rolling(5, min_periods=1).mean())

    df["games_played_before"] = group.cumcount()
    df["is_home"] = df["matchup"].astype(str).str.contains("vs.", case=False, na=False).astype(int)
    df["is_away"] = df["matchup"].astype(str).str.contains("@", na=False).astype(int)

    return df


def build_training_data(df: pd.DataFrame):
    if df.empty:
        return df, [], pd.DataFrame(), pd.Series(dtype=float)

    df = add_rolling_features(df)

    feature_cols = [
        "games_played_before",
        "is_home",
        "is_away",
        "ast_last3", "ast_last5",
        "reb_last3", "reb_last5",
        "numMinutes_last3", "numMinutes_last5",
        "fg_pct_last3", "fg_pct_last5",
        "fg3_pct_last3", "fg3_pct_last5",
        "ft_pct_last3", "ft_pct_last5",
        "tov_last3", "tov_last5",
        "plus_minus_last3", "plus_minus_last5",
        "points_last3", "points_last5",
        "tm_points_total_last3", "tm_points_total_last5",
        "tm_ast_total_last3", "tm_ast_total_last5",
        "tm_reb_total_last3", "tm_reb_total_last5",
        "tm_minutes_total_last3", "tm_minutes_total_last5",
        "tm_fg_pct_last3", "tm_fg_pct_last5",
        "top_tm_points_last3", "top_tm_points_last5",
        "second_tm_points_last3", "second_tm_points_last5",
        "third_tm_points_last3", "third_tm_points_last5",
        "top3_tm_points_total_last3", "top3_tm_points_total_last5",
        "player_team_points_share_last3", "player_team_points_share_last5",
    ]

    model_df = df.copy()
    model_df = model_df.dropna(subset=["points"])
    model_df = model_df[model_df["games_played_before"] >= 3].copy()

    if model_df.empty:
        return df, feature_cols, pd.DataFrame(), pd.Series(dtype=float)

    X = model_df[feature_cols].copy()
    y = model_df["points"].copy()

    X = X.fillna(X.mean(numeric_only=True))
    X = X.fillna(0)

    return df, feature_cols, X, y


def train_model(X: pd.DataFrame, y: pd.Series):
    if X.empty or y.empty:
        print("No training data available.")
        return None

    if len(X) < 10:
        print("Not enough rows to train a strong model.")
        return None

    test_size = 0.2 if len(X) >= 25 else 0.25

    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=test_size, random_state=42
    )

    model = ExtraTreesRegressor(
        n_estimators=300,
        random_state=42,
        min_samples_leaf=2,
        n_jobs=-1
    )
    model.fit(X_train, y_train)

    preds = model.predict(X_test)

    rmse = float(np.sqrt(mean_squared_error(y_test, preds)))
    mae = float(mean_absolute_error(y_test, preds))
    r2 = float(r2_score(y_test, preds))

    print("\nMODEL EVALUATION")
    print("-" * 50)
    print(f"Rows used: {len(X)}")
    print(f"RMSE: {rmse:.3f}")
    print(f"MAE : {mae:.3f}")
    print(f"R²  : {r2:.3f}")

    return model


def build_prediction_rows(df: pd.DataFrame, feature_cols, active_players):
    prediction_rows = []

    for player in active_players:
        player_df = df[df["full_name"] == player].sort_values("game_date").copy()

        if len(player_df) < 3:
            print(f"Skipping prediction for {player}: not enough game history.")
            continue

        row = {"full_name": player}
        row["games_played_before"] = len(player_df)
        row["is_home"] = 1
        row["is_away"] = 0

        rolling_base_cols = [
            "points", "ast", "reb", "numMinutes", "fg_pct", "fg3_pct", "ft_pct",
            "tov", "plus_minus", "tm_points_total", "tm_ast_total", "tm_reb_total",
            "tm_minutes_total", "tm_fg_pct", "top_tm_points", "second_tm_points",
            "third_tm_points", "top3_tm_points_total", "player_team_points_share"
        ]

        for base_col in rolling_base_cols:
            recent3 = player_df[base_col].tail(3).mean()
            recent5 = player_df[base_col].tail(5).mean()
            row[f"{base_col}_last3"] = float(recent3) if pd.notna(recent3) else 0.0
            row[f"{base_col}_last5"] = float(recent5) if pd.notna(recent5) else 0.0

        prediction_rows.append(row)

    if not prediction_rows:
        return pd.DataFrame()

    pred_df = pd.DataFrame(prediction_rows)

    for col in feature_cols:
        if col not in pred_df.columns:
            pred_df[col] = 0.0

    pred_df = pred_df[["full_name"] + feature_cols].copy()
    pred_df[feature_cols] = pred_df[feature_cols].apply(pd.to_numeric, errors="coerce").fillna(0)

    return pred_df


def predict_next_game_points(model, pred_df: pd.DataFrame, feature_cols):
    if model is None or pred_df.empty:
        return {}

    X_pred = pred_df[feature_cols].copy()
    preds = model.predict(X_pred)

    results = {}
    for player, pred in zip(pred_df["full_name"], preds):
        results[player] = round(max(0.0, float(pred)), 1)

    return results


def predict_team_score(player_predictions: dict):
    return round(sum(player_predictions.values()), 1)


