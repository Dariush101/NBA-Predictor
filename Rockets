def get_current_season():
    today = datetime.now()
    year = today.year
    month = today.month

    if month >= 10:  # October or later → new season
        start_year = year
    else:  # Jan–Sept → still previous season
        start_year = year - 1

    end_year_short = str(start_year + 1)[-2:]
    return f"{start_year}-{end_year_short}"



