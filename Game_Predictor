def predict_team(
    config: TeamConfig,
    is_home: int,
    game_adjustment: float,
) -> Tuple[pd.DataFrame, Dict[str, float], List[str], List[str]]:
    df_all = load_team_data(config.db_path, config.players)
    if df_all.empty:
        print(f"No data found for {config.name}.")
        return pd.DataFrame(), {s: 0.0 for s in BOX_STATS}, [], []

    auto_injured = detect_injuries_from_recent_participation(df_all, config.players)
    combined_injured = sorted(set(config.manual_injured) | set(auto_injured))
    healthy_players = [p for p in config.players if p not in combined_injured]

    rotation_players = detect_playoff_rotation_players(
        df_all,
        healthy_players,
        recent_team_games_window=RECENT_GAMES_FOR_ROTATION,
        min_avg_minutes=PLAYOFF_MIN_AVG_MINUTES,
        max_players=PLAYOFF_ROTATION_SIZE,
    )

    print_team_availability(config.name, combined_injured, rotation_players)

    df_active = load_team_data(config.db_path, rotation_players)
    if df_active.empty:
        print(f"No active playoff-rotation data found for {config.name}.")
        return pd.DataFrame(), {s: 0.0 for s in BOX_STATS}, combined_injured, rotation_players

    minute_model, stat_models, feature_cols, full_df = train_models(df_active)
    pred_rows = build_prediction_rows(full_df, rotation_players, feature_cols, is_home=is_home)
    player_preds = predict_player_box_stats(minute_model, stat_models, pred_rows, feature_cols, full_df)
    player_preds = enrich_with_shooting_estimates(player_preds, full_df)

    team_base_stats = fetch_team_base_stats(config.name, SEASON)
    player_preds, totals = calibrate_team_predictions(player_preds, team_base_stats, game_adjustment=game_adjustment)

    return player_preds, totals, combined_injured, rotation_players


