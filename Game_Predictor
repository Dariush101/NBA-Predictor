            f"FG% {row['fg_pct']:.3f} | 3PT% {row['fg3_pct']:.3f} | FT% {row['ft_pct']:.3f}"
        )


def simulate_series(lakers: TeamConfig, rockets: TeamConfig):
    home_pattern = get_series_home_pattern(HIGHER_SEED_TEAM, LOWER_SEED_TEAM)

    lakers_wins = 0
    rockets_wins = 0
    series_results = []

    # mild game-to-game variability by slot
    game_adjustments = [1.00, 0.98, 1.01, 0.99, 1.02, 1.00, 0.97]

    for game_num, home_team in enumerate(home_pattern, start=1):
        if lakers_wins == 4 or rockets_wins == 4:
            break

        print("\n" + "=" * 100)
        print(f"GAME {game_num}")
        print("=" * 100)

        lakers_is_home = 1 if home_team == "Los Angeles Lakers" else 0
        rockets_is_home = 1 if home_team == "Houston Rockets" else 0

        print(f"Home team: {home_team}")

        game_adj = game_adjustments[game_num - 1]

        lakers_player_preds, lakers_totals, _, _ = predict_team(
            lakers,
            is_home=lakers_is_home,
            game_adjustment=game_adj + (0.015 if lakers_is_home else -0.015),
        )

        rockets_player_preds, rockets_totals, _, _ = predict_team(
            rockets,
            is_home=rockets_is_home,
            game_adjustment=game_adj + (0.015 if rockets_is_home else -0.015),
        )

        # prevent ties
        if lakers_totals["points"] == rockets_totals["points"]:
            if lakers_is_home:
                lakers_totals["points"] += 1.0
            else:
                rockets_totals["points"] += 1.0

        if lakers_totals["points"] > rockets_totals["points"]:
            winner = "Los Angeles Lakers"
            lakers_wins += 1
        else:
            winner = "Houston Rockets"
            rockets_wins += 1

        print(f"Predicted Winner: {winner}")
        print(f"Predicted Score: Lakers {lakers_totals['points']:.1f} - Rockets {rockets_totals['points']:.1f}")
        print("-" * 100)
        print("LAKERS")
        print_team_prediction("Los Angeles Lakers", lakers_player_preds, lakers_totals)
        print("-" * 100)
        print("ROCKETS")
