def load_player(player_name: str):
    conn = sqlite3.connect(DB_PATH)

    query = f"""
    SELECT
        season,
        game_date,
        matchup,
        wl,
        numMinutes,
        points,
        ast,
        reb,
        stl,
        blk,
        tov,
        fg_pct,
        fg3_pct,
        ft_pct,
        plus_minus,
        tm_points_total,
        tm_ast_total,
        tm_reb_total,
        tm_minutes_total,
        tm_fg_pct,
        top_tm_points,
        second_tm_points,
        third_tm_points,
        top3_tm_points_total,
        player_team_points_share
    FROM {TABLE}
    WHERE full_name = ?
    ORDER BY game_date
    """

    df = pd.read_sql_query(query, conn, params=(player_name,))
    conn.close()

    numeric_cols = [
        "numMinutes", "points", "ast", "reb", "stl",
        "blk", "tov", "fg_pct", "fg3_pct", "ft_pct", "plus_minus",
        "tm_points_total", "tm_ast_total", "tm_reb_total", "tm_minutes_total", "tm_fg_pct",
        "top_tm_points", "second_tm_points", "third_tm_points",
        "top3_tm_points_total", "player_team_points_share"
    ]

    for col in numeric_cols:
        df[col] = pd.to_numeric(df[col], errors="coerce")

    df["game_date"] = pd.to_datetime(df["game_date"], errors="coerce")
    df = df.dropna(subset=["game_date", "numMinutes", "points", "ast", "reb", "matchup"])
    df = df.sort_values("game_date").reset_index(drop=True)

    return df


def add_playoff_flag(df):
    df = df.copy()

    # Assumption:
    # if the season text contains "playoff", treat it as a playoff row.
    # If your DB stores only season years like 2024-25, then all rows become 0
    # unless you add a dedicated season_type column later.
    df["is_playoff"] = df["season"].astype(str).str.contains("playoff", case=False, na=False).astype(int)

    return df


def extract_opponent(matchup: str):
    matchup = str(matchup).strip()

    if "vs." in matchup:
        return matchup.split("vs.")[-1].strip(), 1
    if "@" in matchup:
        return matchup.split("@")[-1].strip(), 0

    return None, None


def add_basic_context(df):
    df = df.copy()

    extracted = df["matchup"].apply(extract_opponent)
    df["opponent"] = extracted.apply(lambda x: x[0])
    df["is_home"] = extracted.apply(lambda x: x[1])

    df = df.dropna(subset=["opponent", "is_home"]).reset_index(drop=True)
    df["is_home"] = df["is_home"].astype(int)

    return df


