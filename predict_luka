def compute_trend_info(df, days=21):
    df = df.copy().sort_values("game_date").reset_index(drop=True)

    latest_date = df["game_date"].max()
    cutoff_date = latest_date - pd.Timedelta(days=days)

    recent_df = df[df["game_date"] >= cutoff_date].copy()

    recent_avg = recent_df["points"].mean() if not recent_df.empty else np.nan
    overall_avg = df["points"].mean() if not df.empty else np.nan
    trend_diff = recent_avg - overall_avg if pd.notna(recent_avg) and pd.notna(overall_avg) else np.nan

    if pd.isna(trend_diff):
        status = "UNKNOWN"
    elif trend_diff > 2:
        status = "HOT"
    elif trend_diff < -2:
        status = "SLUMP"
    else:
        status = "NORMAL"

    return {
        "recent_avg": recent_avg,
        "overall_avg": overall_avg,
        "trend_diff": trend_diff,
        "status": status,
        "games_in_window": len(recent_df),
        "window_days": days,
    }


def compute_regular_vs_playoff_gap(df):
    regular_df = df[df["is_playoff"] == 0].copy()
    playoff_df = df[df["is_playoff"] == 1].copy()

    regular_avg = regular_df["points"].mean() if not regular_df.empty else np.nan
    playoff_avg = playoff_df["points"].mean() if not playoff_df.empty else np.nan

    if pd.notna(regular_avg) and pd.notna(playoff_avg):
        diff = playoff_avg - regular_avg
    else:
        diff = np.nan

    return {
        "regular_avg": regular_avg,
        "playoff_avg": playoff_avg,
        "playoff_minus_regular": diff
    }


