    next_is_home = int(next_game_context["is_home"])
    next_is_playoff = 1 if assume_playoff else 0

    opp_hist = raw_df[raw_df["opponent"] == next_opponent].copy()

    if opp_hist.empty:
        opp_games_before = 0
        opp_avg_points_before = raw_df["points"].mean()
        opp_median_points_before = raw_df["points"].median()
        opp_std_points_before = raw_df["points"].std()
        opp_max_points_before = raw_df["points"].max()
        opp_avg_ast_before = raw_df["ast"].mean()
        opp_avg_reb_before = raw_df["reb"].mean()
        opp_avg_minutes_before = raw_df["numMinutes"].mean()
        opp_fg_pct_before = raw_df["fg_pct"].mean()
    else:
        opp_games_before = len(opp_hist)
        opp_avg_points_before = opp_hist["points"].mean()
        opp_median_points_before = opp_hist["points"].median()
        opp_std_points_before = opp_hist["points"].std()
        opp_max_points_before = opp_hist["points"].max()
        opp_avg_ast_before = opp_hist["ast"].mean()
        opp_avg_reb_before = opp_hist["reb"].mean()
        opp_avg_minutes_before = opp_hist["numMinutes"].mean()
        opp_fg_pct_before = opp_hist["fg_pct"].mean()

    if pd.isna(opp_std_points_before):
        opp_std_points_before = 0.0

    latest_date = raw_df["game_date"].max()
    cutoff_date = latest_date - pd.Timedelta(days=21)
