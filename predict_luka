def get_player_id(full_name: str) -> int:
    matches = players.find_players_by_full_name(full_name)
    if not matches:
        raise ValueError(f"Player '{full_name}' not found.")
    return int(matches[0]["id"])


def get_current_season_string(today=None) -> str:
    if today is None:
        today = dt.date.today()

    if today.month >= 7:
        start_year = today.year
    else:
        start_year = today.year - 1

    end_year_short = str(start_year + 1)[-2:]
    return f"{start_year}-{end_year_short}"


def get_team_abbreviation_from_matchup(matchup: str) -> str:
    matchup = str(matchup).strip()

    if "vs." in matchup:
        return matchup.split("vs.")[0].strip()
    if "@" in matchup:
        return matchup.split("@")[0].strip()

    raise ValueError(f"Could not parse team abbreviation from matchup: {matchup}")


def get_player_team_abbreviation_from_db(player_name: str) -> str:
    conn = sqlite3.connect(DB_PATH)

    query = f"""
    SELECT matchup
    FROM {TABLE}
    WHERE full_name = ?
    ORDER BY game_date DESC
    LIMIT 1
    """

    df = pd.read_sql_query(query, conn, params=(player_name,))
    conn.close()

    if df.empty:
        raise ValueError(f"Could not determine {player_name}'s team from database.")

    return get_team_abbreviation_from_matchup(df.iloc[0]["matchup"])


def get_next_game_from_playernextngames(player_name: str, season=None):
    if season is None:
        season = get_current_season_string()

    player_id = get_player_id(player_name)
    player_team_abbr = get_player_team_abbreviation_from_db(player_name)

    try:
        df = playernextngames.PlayerNextNGames(
            player_id=player_id,
            number_of_games=1,
            season_all=season,
            season_type_all_star="Regular Season"
        ).get_data_frames()[0]

        if df.empty:
            return None

        row = df.iloc[0]
        home_abbr = str(row["HOME_TEAM_ABBREVIATION"]).strip()
        visitor_abbr = str(row["VISITOR_TEAM_ABBREVIATION"]).strip()

        if home_abbr == player_team_abbr:
            return {
                "source": "PlayerNextNGames",
                "game_id": row.get("GAME_ID"),
                "game_date": row.get("GAME_DATE"),
                "opponent": visitor_abbr,
                "is_home": 1,
                "home_team": home_abbr,
                "visitor_team": visitor_abbr,
            }

        if visitor_abbr == player_team_abbr:
            return {
                "source": "PlayerNextNGames",
                "game_id": row.get("GAME_ID"),
                "game_date": row.get("GAME_DATE"),
                "opponent": home_abbr,
                "is_home": 0,
                "home_team": home_abbr,
                "visitor_team": visitor_abbr,
            }

        return None

    except Exception:
        return None


def normalize_schedule_date(value):
    if value is None:
        return None

    text = str(value).strip()

    for fmt in ("%Y-%m-%d", "%Y-%m-%dT%H:%M:%S"):
        try:
            return dt.datetime.strptime(text[:19], fmt).date()
        except ValueError:
            pass

    try:
        return pd.to_datetime(text).date()
    except Exception:
        return None


def get_next_game_from_full_schedule(player_name: str, season=None):
    if season is None:
        season = get_current_season_string()

    player_team_abbr = get_player_team_abbreviation_from_db(player_name)
    start_year = season.split("-")[0]

    url = f"https://data.nba.com/data/10s/v2015/json/mobile_teams/nba/{start_year}/league/00_full_schedule.json"

    try:
        response = requests.get(url, timeout=20)
        response.raise_for_status()
        data = response.json()
    except Exception:
        return None

    today = dt.date.today()
    games = []

    months = data.get("lscd", [])
    for month_block in months:
        for game in month_block.get("mscd", {}).get("g", []):
            game_date = normalize_schedule_date(game.get("gdte"))
            if game_date is None or game_date < today:
                continue

            home = str(game.get("h", {}).get("ta", "")).strip()
            away = str(game.get("v", {}).get("ta", "")).strip()

            if player_team_abbr not in (home, away):
                continue

            if home == player_team_abbr:
                opponent = away
                is_home = 1
            else:
                opponent = home
                is_home = 0

            games.append({
                "source": "full_schedule_json",
                "game_id": game.get("gid"),
                "game_date": game_date.isoformat(),
                "opponent": opponent,
                "is_home": is_home,
                "home_team": home,
                "visitor_team": away,
            })

    if not games:
        return None

    games.sort(key=lambda x: (x["game_date"], x["game_id"] or ""))
    return games[0]


def get_next_game_context(player_name: str, season=None):
    next_game = get_next_game_from_playernextngames(player_name=player_name, season=season)
    if next_game is not None:
        return next_game

    next_game = get_next_game_from_full_schedule(player_name=player_name, season=season)
    if next_game is not None:
        return next_game

    print(f"Warning: could not automatically determine {player_name}'s next game.")
    return None


