def run_for_player(player_name: str, assume_playoff=True):
    raw_df = load_player(player_name)

    if raw_df.empty:
        print(f"No data found for {player_name}. Run viewer.py first.")
        return

    raw_df = add_basic_context(raw_df)
    raw_df = add_playoff_flag(raw_df)

    print_last_games(raw_df, player_name, n=10)

    opponent_summary = build_opponent_summary(raw_df)
    print_opponent_report(opponent_summary, player_name)

    regular_vs_playoff_summary = build_regular_vs_playoff_summary(raw_df)
    print_regular_vs_playoff_report(regular_vs_playoff_summary, player_name)

    trend_info = compute_trend_info(raw_df, days=21)
    print_trend_info(trend_info, player_name)

    playoff_gap = compute_regular_vs_playoff_gap(raw_df)
    print_regular_vs_playoff_gap(playoff_gap, player_name)

    print_prescriptive_steps(player_name)

    next_game_context = get_next_game_context(player_name)
    subsets = get_subsets(raw_df)

    if next_game_context is not None:
        print(f"\nNext game detected automatically for {player_name}:")
        print(next_game_context)

        season_result = run_window(
            player_name, "season", subsets["season"], next_game_context, assume_playoff=assume_playoff
        )
        career_result = run_window(
            player_name, "career", subsets["career"], next_game_context, assume_playoff=assume_playoff
        )

        # optional extra playoff-only modeling section
        if not subsets["playoffs"].empty and len(subsets["playoffs"]) >= 10:
            run_window(
                player_name, "playoffs", subsets["playoffs"], next_game_context, assume_playoff=True
            )

        blended = build_blended_prediction(
            season_result=season_result,
            career_result=career_result,
            opponent_summary=opponent_summary,
            trend_info=trend_info,
            opponent=next_game_context["opponent"],
            playoff_gap=playoff_gap if assume_playoff else None,
        )

        print_prediction_summary(player_name, next_game_context, blended, assume_playoff=assume_playoff)
    else:
        print(f"\nSkipping next-game prediction for {player_name} because no next game was found.")

        run_window(player_name, "season", subsets["season"], None, assume_playoff=assume_playoff)
        run_window(player_name, "career", subsets["career"], None, assume_playoff=assume_playoff)

        if not subsets["playoffs"].empty and len(subsets["playoffs"]) >= 10:
            run_window(player_name, "playoffs", subsets["playoffs"], None, assume_playoff=True)


