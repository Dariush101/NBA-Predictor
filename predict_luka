def build_opponent_summary(df):
    summary = (
        df.groupby("opponent")
        .agg(
            games=("points", "count"),
            avg_points=("points", "mean"),
            median_points=("points", "median"),
            std_points=("points", "std"),
            min_points=("points", "min"),
            max_points=("points", "max"),
            avg_ast=("ast", "mean"),
            avg_reb=("reb", "mean"),
            avg_minutes=("numMinutes", "mean"),
            fg_pct=("fg_pct", "mean"),
            wins=("wl", lambda s: (s == "W").sum()),
            losses=("wl", lambda s: (s == "L").sum())
        )
        .reset_index()
    )

    summary["win_pct"] = np.where(
        (summary["wins"] + summary["losses"]) > 0,
        summary["wins"] / (summary["wins"] + summary["losses"]),
        np.nan
    )

    return summary.sort_values(["avg_points", "games"], ascending=[False, False]).reset_index(drop=True)


def build_regular_vs_playoff_summary(df):
    summary = (
        df.groupby("is_playoff")
        .agg(
            games=("points", "count"),
            avg_points=("points", "mean"),
            median_points=("points", "median"),
            avg_ast=("ast", "mean"),
            avg_reb=("reb", "mean"),
            avg_minutes=("numMinutes", "mean"),
            avg_fg_pct=("fg_pct", "mean")
        )
        .reset_index()
    )

    summary["game_type"] = summary["is_playoff"].map({0: "Regular Season", 1: "Playoffs"})
    return summary[[
        "game_type", "games", "avg_points", "median_points",
        "avg_ast", "avg_reb", "avg_minutes", "avg_fg_pct"
    ]]


