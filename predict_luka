# =========================================================

def build_blended_prediction(season_result, career_result, opponent_summary, trend_info, opponent, playoff_gap=None):
    season_pred = season_result["prediction"] if season_result else None
    career_pred = career_result["prediction"] if career_result else None

    opp_row = opponent_summary[opponent_summary["opponent"] == opponent]
    if not opp_row.empty:
        opp_avg = float(opp_row.iloc[0]["avg_points"])
        opp_std = float(opp_row.iloc[0]["std_points"])
    else:
        opp_avg = np.nan
        opp_std = np.nan

    pieces = []

    if season_pred is not None:
        pieces.append(("season", season_pred, 0.45))
    if career_pred is not None:
        pieces.append(("career", career_pred, 0.30))
    if pd.notna(opp_avg):
        pieces.append(("opponent_avg", opp_avg, 0.25))

    numerator = sum(value * weight for _, value, weight in pieces)
    denominator = sum(weight for _, _, weight in pieces)
    base_blend = numerator / denominator if denominator > 0 else np.nan

    trend_diff = trend_info["trend_diff"]
    if pd.isna(trend_diff):
        trend_adjustment = 0.0
    else:
        trend_adjustment = max(-3.0, min(3.0, trend_diff * 0.20))

    playoff_adjustment = 0.0
    if playoff_gap is not None and pd.notna(playoff_gap.get("playoff_minus_regular")):
        playoff_adjustment = max(-4.0, min(4.0, playoff_gap["playoff_minus_regular"] * 0.35))

    final_prediction = base_blend + trend_adjustment + playoff_adjustment

    if pd.isna(opp_std) or opp_std <= 0:
        low = max(0.0, final_prediction - 5)
        high = final_prediction + 5
    else:
        spread = max(5.0, min(opp_std * 0.60, 9.0))
        low = max(0.0, final_prediction - spread)
        high = final_prediction + spread

    return {
        "season_pred": season_pred,
        "career_pred": career_pred,
        "opp_avg": opp_avg,
        "opp_std": opp_std,
        "trend_diff": trend_diff,
        "trend_status": trend_info["status"],
        "trend_adjustment": trend_adjustment,
        "playoff_adjustment": playoff_adjustment,
        "final_prediction": final_prediction,
        "range_low": low,
        "range_high": high,
    }


