def add_opponent_history_features(df):
    df = df.copy().sort_values("game_date").reset_index(drop=True)

    df["opp_games_before"] = 0
    df["opp_avg_points_before"] = np.nan
    df["opp_median_points_before"] = np.nan
    df["opp_std_points_before"] = np.nan
    df["opp_max_points_before"] = np.nan
    df["opp_avg_ast_before"] = np.nan
    df["opp_avg_reb_before"] = np.nan
    df["opp_avg_minutes_before"] = np.nan
    df["opp_fg_pct_before"] = np.nan

    for opp in df["opponent"].unique():
        mask = df["opponent"] == opp
        sub = df.loc[mask].copy()

        df.loc[mask, "opp_games_before"] = np.arange(len(sub))
        df.loc[mask, "opp_avg_points_before"] = sub["points"].shift(1).expanding().mean().values
        df.loc[mask, "opp_median_points_before"] = sub["points"].shift(1).expanding().median().values
        df.loc[mask, "opp_std_points_before"] = sub["points"].shift(1).expanding().std().values
        df.loc[mask, "opp_max_points_before"] = sub["points"].shift(1).expanding().max().values
        df.loc[mask, "opp_avg_ast_before"] = sub["ast"].shift(1).expanding().mean().values
        df.loc[mask, "opp_avg_reb_before"] = sub["reb"].shift(1).expanding().mean().values
        df.loc[mask, "opp_avg_minutes_before"] = sub["numMinutes"].shift(1).expanding().mean().values
        df.loc[mask, "opp_fg_pct_before"] = sub["fg_pct"].shift(1).expanding().mean().values

    return df


def add_trend_features(df, days=21):
    df = df.copy().sort_values("game_date").reset_index(drop=True)

    df["recent_3w_avg"] = np.nan
    df["season_avg_to_date"] = np.nan
    df["trend_diff"] = np.nan

    for i in range(len(df)):
        current_date = df.loc[i, "game_date"]
        history = df.iloc[:i].copy()

        if history.empty:
            continue

        cutoff_date = current_date - pd.Timedelta(days=days)
        recent_history = history[history["game_date"] >= cutoff_date].copy()

        recent_avg = recent_history["points"].mean() if not recent_history.empty else history["points"].mean()
        season_avg = history["points"].mean()
        diff = recent_avg - season_avg

        df.loc[i, "recent_3w_avg"] = recent_avg
        df.loc[i, "season_avg_to_date"] = season_avg
        df.loc[i, "trend_diff"] = diff

    return df


def add_recent_form_features(df):
    df = df.copy().sort_values("game_date").reset_index(drop=True)

    df["prev_points"] = df["points"].shift(1)
    df["prev_minutes"] = df["numMinutes"].shift(1)
    df["prev_ast"] = df["ast"].shift(1)
    df["prev_reb"] = df["reb"].shift(1)
    df["prev_stl"] = df["stl"].shift(1)
    df["prev_blk"] = df["blk"].shift(1)
    df["prev_tov"] = df["tov"].shift(1)
    df["prev_fg_pct"] = df["fg_pct"].shift(1)
    df["prev_fg3_pct"] = df["fg3_pct"].shift(1)
    df["prev_ft_pct"] = df["ft_pct"].shift(1)
    df["prev_plus_minus"] = df["plus_minus"].shift(1)

    df["avg_points_3"] = df["points"].shift(1).rolling(3).mean()
    df["avg_points_5"] = df["points"].shift(1).rolling(5).mean()
    df["avg_minutes_3"] = df["numMinutes"].shift(1).rolling(3).mean()
    df["avg_ast_3"] = df["ast"].shift(1).rolling(3).mean()
    df["avg_reb_3"] = df["reb"].shift(1).rolling(3).mean()
    df["avg_fg_pct_3"] = df["fg_pct"].shift(1).rolling(3).mean()

    df["prev_tm_points_total"] = df["tm_points_total"].shift(1)
    df["prev_tm_ast_total"] = df["tm_ast_total"].shift(1)
    df["prev_tm_reb_total"] = df["tm_reb_total"].shift(1)
    df["prev_tm_minutes_total"] = df["tm_minutes_total"].shift(1)
    df["prev_tm_fg_pct"] = df["tm_fg_pct"].shift(1)

    df["avg_tm_points_3"] = df["tm_points_total"].shift(1).rolling(3).mean()
    df["avg_tm_points_5"] = df["tm_points_total"].shift(1).rolling(5).mean()
    df["avg_tm_ast_3"] = df["tm_ast_total"].shift(1).rolling(3).mean()
    df["avg_tm_reb_3"] = df["tm_reb_total"].shift(1).rolling(3).mean()
    df["avg_tm_minutes_3"] = df["tm_minutes_total"].shift(1).rolling(3).mean()
    df["avg_tm_fg_pct_3"] = df["tm_fg_pct"].shift(1).rolling(3).mean()

    df["team_avg_points_3"] = df["tm_points_total"].shift(1).rolling(3).mean()
    df["team_avg_points_5"] = df["tm_points_total"].shift(1).rolling(5).mean()

    df["prev_top_tm_points"] = df["top_tm_points"].shift(1)
    df["prev_second_tm_points"] = df["second_tm_points"].shift(1)
    df["prev_third_tm_points"] = df["third_tm_points"].shift(1)
    df["prev_top3_tm_points_total"] = df["top3_tm_points_total"].shift(1)
    df["prev_player_team_points_share"] = df["player_team_points_share"].shift(1)

    df["avg_top_tm_points_3"] = df["top_tm_points"].shift(1).rolling(3).mean()
    df["avg_second_tm_points_3"] = df["second_tm_points"].shift(1).rolling(3).mean()
    df["avg_third_tm_points_3"] = df["third_tm_points"].shift(1).rolling(3).mean()
    df["avg_top3_tm_points_total_3"] = df["top3_tm_points_total"].shift(1).rolling(3).mean()
    df["avg_player_team_points_share_3"] = df["player_team_points_share"].shift(1).rolling(3).mean()
    df["player_usage_trend_3"] = df["player_team_points_share"].shift(1).rolling(3).mean()

    # playoff-aware features
    df["prev_is_playoff"] = df["is_playoff"].shift(1)
    df["playoff_points_boost"] = df["points"].shift(1) * df["is_playoff"]
    df["playoff_minutes_boost"] = df["numMinutes"].shift(1) * df["is_playoff"]
    df["playoff_usage_boost"] = df["player_team_points_share"].shift(1) * df["is_playoff"]
    df["avg_playoff_points_3"] = (
        df["points"].shift(1).where(df["is_playoff"].shift(1) == 1).rolling(3).mean()
    )

    return df


def finalize_feature_table(df):
    df = df.copy().sort_values("game_date").reset_index(drop=True)

    opponent_fill_cols = [
        "opp_avg_points_before",
        "opp_median_points_before",
        "opp_std_points_before",
        "opp_max_points_before",
        "opp_avg_ast_before",
        "opp_avg_reb_before",
        "opp_avg_minutes_before",
        "opp_fg_pct_before",
    ]

    for col in opponent_fill_cols:
        if "points" in col:
            df[col] = df[col].fillna(df["points"].expanding().mean())
        elif "ast" in col:
            df[col] = df[col].fillna(df["ast"].expanding().mean())
        elif "reb" in col:
            df[col] = df[col].fillna(df["reb"].expanding().mean())
        elif "minutes" in col:
            df[col] = df[col].fillna(df["numMinutes"].expanding().mean())
        elif "fg_pct" in col:
            df[col] = df[col].fillna(df["fg_pct"].expanding().mean())
        else:
            df[col] = df[col].fillna(0)

    trend_fill_cols = [
        "recent_3w_avg",
        "season_avg_to_date",
        "trend_diff",
        "avg_playoff_points_3",
    ]

    for col in trend_fill_cols:
        if col in ("recent_3w_avg", "season_avg_to_date", "avg_playoff_points_3"):
            df[col] = df[col].fillna(df["points"].expanding().mean())
        else:
            df[col] = df[col].fillna(0)

    df["opp_std_points_before"] = df["opp_std_points_before"].fillna(0)
    df["opp_games_before"] = df["opp_games_before"].fillna(0)
    df["prev_is_playoff"] = df["prev_is_playoff"].fillna(0)
    df["playoff_points_boost"] = df["playoff_points_boost"].fillna(0)
    df["playoff_minutes_boost"] = df["playoff_minutes_boost"].fillna(0)
    df["playoff_usage_boost"] = df["playoff_usage_boost"].fillna(0)

    df = df.dropna().reset_index(drop=True)
    return df


