def run_window(player_name, window_name, raw_window_df, next_game_context, assume_playoff=False):
    if raw_window_df.empty:
        print(f"\nNo data for {player_name} window: {window_name}")
        return None

    feature_df = add_opponent_history_features(raw_window_df)
    feature_df = add_recent_form_features(feature_df)
    feature_df = add_trend_features(feature_df, days=21)
    feature_df = finalize_feature_table(feature_df)

    if feature_df.empty or len(feature_df) < 10:
        print(f"\nNot enough rows after feature engineering for {player_name} window: {window_name}")
        return None

    feature_cols = get_feature_columns()
    split_result = split_train_test(feature_df, feature_cols)
    if split_result is None:
        print(f"\nNot enough rows for train/test split in {player_name} window: {window_name}")
        return None

    X_train, X_test, y_train, y_test, train_df, test_df = split_result

    print("\n" + "=" * 110)
    print(f"PLAYER: {player_name.upper()} | WINDOW: {window_name.upper()}")
    print("=" * 110)
    print(f"Rows after features: {len(feature_df)}")
    print(f"Train rows (80%): {len(train_df)}")
    print(f"Test rows  (20%): {len(test_df)}")

    models = get_models()
    results = []

    for model_name, model in models.items():
        result = evaluate_model(model_name, model, X_train, X_test, y_train, y_test)
        results.append(result)

        plot_model_results(window_name, model_name, player_name, test_df, y_test, result["preds"])

    print_model_results(results, window_name, player_name)
    print_actual_vs_predicted(results, y_test)

    best_result = min(results, key=lambda x: x["rmse"])
    best_model = best_result["model"]

    print(f"\nBest model for {player_name} {window_name}: {best_result['name']}")

    next_pred = None
    if next_game_context is not None:
        next_game_X = build_next_game_row(
            raw_window_df,
            next_game_context,
            assume_playoff=assume_playoff
        )[feature_cols]
        next_pred = float(best_model.predict(next_game_X)[0])
        print(f"Predicted {player_name} points next game: {next_pred:.2f}")
    else:
        print(f"No next game context available for {player_name}. Prediction skipped.")

    return {
        "window": window_name,
        "best_model_name": best_result["name"],
        "rmse": best_result["rmse"],
        "mae": best_result["mae"],
        "r2": best_result["r2"],
        "prediction": next_pred,
    }


